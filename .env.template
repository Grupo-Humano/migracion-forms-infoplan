# Sprint 1 - Database Configuration Template
# IMPORTANTE: 
#   1. Copia este archivo a .env: cp .env.template .env
#   2. Completa los valores con tus credenciales reales
#   3. NUNCA comitees .env a git (está en .gitignore)

# ===== Oracle Database Connection =====
DB_USER=usuario_aqui
DB_PASSWORD=contrasena_aqui
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=HUMANO_DESA

# ===== SQLcl Configuration =====
# Si SQLcl no está en PATH, proporciona ruta completa
SQLCL_PATH=sqlcl

# ===== Logging =====
DEBUG=false
