# Local dev recommendation (with Vite proxy in vite.config.ts):
# VITE_ORDS_BASE_URL=/ords/infoplan/facturacion/api/v1/aprobaciones-rechazos
# If ORDS module is published directly under base_path '/aprobaciones-rechazos/':
# VITE_ORDS_BASE_URL=/ords/infoplan/aprobaciones-rechazos
#
# Direct backend URL (only if CORS is configured server-side):
VITE_ORDS_BASE_URL=http://localhost:8080/ords/infoplan/facturacion/api/v1/aprobaciones-rechazos
VITE_DEMO_MODE=false
