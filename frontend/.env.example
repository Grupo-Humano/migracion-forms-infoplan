# Local dev recommendation (with Vite proxy in vite.config.ts):
# VITE_ORDS_BASE_URL=/ords/infoplan/facturacion/api/v1/aprobaciones-rechazos
# If ORDS module is published directly under base_path '/aprobaciones-rechazos/':
# VITE_ORDS_BASE_URL=/ords/infoplan/aprobaciones-rechazos
#
# Direct backend URL (only if CORS is configured server-side):
VITE_ORDS_BASE_URL=http://localhost:8080/ords/infoplan/facturacion/api/v1/aprobaciones-rechazos
VITE_DEMO_MODE=false

# Optional OAuth client-credentials config for ORDS protected endpoints
# VITE_ORDS_TOKEN_URL=https://infoplan-web-dev.humano.local/ords/infoplan/oauth/token
# VITE_ORDS_BASIC_AUTH=<base64(client_id:client_secret)>

# Jasper real button (legacy full-data contract)
# VITE_JASPER_FULLDATA_URL=http://172.24.208.208:31522/api/report
# VITE_JASPER_FULLDATA_NAME=fac_localg
# VITE_JASPER_FULLDATA_DOCUMENT_TYPE=PDF
# VITE_JASPER_FULLDATA_USUARIO=LURICHIEZ

# Jasper XML legacy contract (P_JASPER_A_EXCEL from Oracle Forms)
# VITE_JASPER_XML_BASE_URL=http://172.24.208.208:31522/api/report?null=null
# VITE_JASPER_XML_COD_COMPANIA=30
